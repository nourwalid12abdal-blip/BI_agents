# .env  — never commit this file

# LLM
OPENAI_API_KEY=
OPENAI_MODEL=


GROQ_API_KEY=""

# Best model for classification + code generation
GROQ_MODEL=""

HF_MODEL=""
HF_TOKEN=""
# SQL — start with SQLite, swap to Postgres later with no code changes
SQL_DB_URL=sqlite:///./bi_agent.db
# SQL_DB_URL=postgresql://user:password@localhost:5432/bi_agent   ← Postgres

# MongoDB
MONGO_URI=""

MONGO_DB_NAME=bi_agent_dev

# App
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# Schema
SCHEMA_GRAPH_PATH=./schema_graph.json
SCHEMA_SAMPLE_LIMIT=50

# Cache (Redis — leave blank to skip caching in early phases)
REDIS_URL=
CACHE_TTL_SECONDS=300

# Vector store (Qdrant — leave blank to skip in early phases)
VECTOR_STORE_URL=
VECTOR_COLLECTION_NAME=bi_schema